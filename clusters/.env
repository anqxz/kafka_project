# Central version pins. Every services/*/Dockerfile takes a BASE_TAG (or
# equivalent) ARG that defaults to the value here. Override per environment
# by setting the same variable in shell before docker compose up.

# Java stack (Confluent Platform)
KAFKA_TAG=7.7.5
CONNECT_TAG=7.7.5
SCHEMA_REGISTRY_TAG=7.7.5
AKHQ_TAG=0.27.1

# Java agents (baked into JVM images)
JMX_EXPORTER_VERSION=1.0.1
OTEL_AGENT_VERSION=2.10.0
S3_CONNECTOR_VERSION=10.5.13

# Observability upstream
PROMETHEUS_TAG=v2.55.1
GRAFANA_TAG=11.6.0
LOKI_TAG=3.5.0
TEMPO_TAG=2.8.0
PYROSCOPE_TAG=1.14.0
ALERTMANAGER_TAG=v0.28.0
BLACKBOX_EXPORTER_TAG=v0.27.0
OTEL_COLLECTOR_TAG=0.157.0
KMINION_TAG=v2.3.3
NTFY_TAG=v2.11.0
LOCALSTACK_TAG=3.8

# New services
MCP_KAFKA_PYTHON_TAG=3.13-slim
LOADGEN_PYTHON_TAG=3.13-slim
CC_VERSION=2.5.146
CC_GRADLE_TAG=8-jdk11
CC_RUNTIME_TAG=11-jre
KROXYLICIOUS_TAG=0.10.0
TOXIPROXY_TAG=2.9.0

# --- Secrets (rotated per environment; phase 5 will source from LocalStack SM) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-real-deployments
NTFY_ALERT_TOPIC=kafka-alerts-c3f8a2d1
NTFY_WATCHDOG_TOPIC=kafka-watchdog-c3f8a2d1
MCP_AUTH_TOKEN=change-me-in-real-deployments
CONNECT_REST_BASIC_USER=connect
CONNECT_REST_BASIC_PASSWORD=change-me-in-real-deployments
SCHEMA_REGISTRY_ADMIN_USER=admin
SCHEMA_REGISTRY_ADMIN_PASSWORD=change-me-in-real-deployments
CRUISE_CONTROL_ADMIN_USER=admin
CRUISE_CONTROL_ADMIN_PASSWORD=change-me-in-real-deployments

# --- Kafka SASL/SCRAM (phase 2 skeleton; toggle SASL_ENABLED=1 once every client is wired) ---
SASL_ENABLED=0
SCRAM_ADMIN_USER=admin
SCRAM_ADMIN_PASSWORD=change-me-in-real-deployments
SCRAM_CONNECT_PASSWORD=change-me-in-real-deployments
SCRAM_SR_PASSWORD=change-me-in-real-deployments
SCRAM_KMINION_PASSWORD=change-me-in-real-deployments
SCRAM_CC_PASSWORD=change-me-in-real-deployments
SCRAM_MCP_PASSWORD=change-me-in-real-deployments
SCRAM_LOADGEN_PASSWORD=change-me-in-real-deployments
SCRAM_AKHQ_PASSWORD=change-me-in-real-deployments

# --- TLS (phase 4 — keystore/truststore passwords) ---
TLS_STORE_PASSWORD=changeit
