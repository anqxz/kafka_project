# Central version pins. Every services/*/Dockerfile takes a BASE_TAG (or
# equivalent) ARG that defaults to the value here. Override per environment
# by setting the same variable in shell before docker compose up.

# Java stack (Confluent Platform)
KAFKA_TAG=7.7.1
CONNECT_TAG=7.7.1
SCHEMA_REGISTRY_TAG=7.7.1
AKHQ_TAG=0.25.1

# Java agents (baked into JVM images)
JMX_EXPORTER_VERSION=1.0.1
OTEL_AGENT_VERSION=2.10.0
S3_CONNECTOR_VERSION=10.5.13

# Observability upstream
PROMETHEUS_TAG=v2.55.0
GRAFANA_TAG=11.2.0
LOKI_TAG=3.2.0
TEMPO_TAG=2.6.0
PYROSCOPE_TAG=1.7.1
ALERTMANAGER_TAG=v0.27.0
BLACKBOX_EXPORTER_TAG=v0.25.0
OTEL_COLLECTOR_TAG=0.156.0
KMINION_TAG=v2.2.11
NTFY_TAG=v2.11.0
LOCALSTACK_TAG=3.8

# New services
MCP_KAFKA_PYTHON_TAG=3.13-slim
LOADGEN_PYTHON_TAG=3.13-slim
CC_VERSION=2.5.138
CC_GRADLE_TAG=8-jdk11
CC_RUNTIME_TAG=11-jre
KROXYLICIOUS_TAG=0.10.0
TOXIPROXY_TAG=2.9.0
