{
  "title": "Admin — Alertmanager",
  "uid": "admin-alertmanager",
  "tags": [
    "admin",
    "alertmanager"
  ],
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Up",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "up{job=\"alertmanager\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Alerts",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(alertmanager_alerts{state=\"active\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Suppressed",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(alertmanager_alerts{state=\"suppressed\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Notifications Failed /5m",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(alertmanager_notifications_failed_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Alerts Received /sec",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (severity) (rate(alertmanager_alerts_received_total[5m]))",
          "refId": "A",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Notifications Sent by Integration",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (integration) (rate(alertmanager_notifications_total[5m]))",
          "refId": "A",
          "legendFormat": "{{integration}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Firing Alerts",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "refId": "A",
          "legendFormat": "{{alertname}} / {{severity}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Logs",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=~\"alertmanager\"} |= ``",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Traces (TraceQL)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlSearch",
          "query": "{resource.service.name=~\"alertmanager\"}",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "limit": 20,
          "tableType": "traces"
        }
      ]
    }
  ]
}
