{
  "title": "Admin — KMinion (Lag & Topics)",
  "uid": "admin-kminion",
  "tags": [
    "admin",
    "kminion",
    "lag"
  ],
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "group",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(kminion_kafka_consumer_group_topic_lag, group_id)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "KMinion Up",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "up{job=\"kminion\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Topics",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(count by (topic_name) (kafka_server_replicamanager_partitioncount))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Consumer Groups",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(count by (group_id) (kminion_kafka_consumer_group_info))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Lag (msgs)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(kminion_kafka_consumer_group_topic_lag)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Lag by Group",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (group_id) (kminion_kafka_consumer_group_topic_lag{group_id=~\"$group\"})",
          "refId": "A",
          "legendFormat": "{{group_id}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Top Lag (group / topic)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(20, sum by (group_id, topic_name) (kminion_kafka_consumer_group_topic_lag))",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Partitions per Topic",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "kafka_server_replicamanager_partitioncount",
          "refId": "A",
          "legendFormat": "{{topic_name}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Logs",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=~\"kminion\"} |= ``",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Traces (TraceQL)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlSearch",
          "query": "{resource.service.name=~\"kminion\"}",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "limit": 20,
          "tableType": "traces"
        }
      ]
    }
  ]
}
