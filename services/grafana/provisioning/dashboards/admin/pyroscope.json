{
  "title": "Admin — Pyroscope",
  "uid": "admin-pyroscope",
  "tags": [
    "admin",
    "pyroscope",
    "profiles"
  ],
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Up",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "up{job=\"pyroscope\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Ingest Bytes /s",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(pyroscope_distributor_received_compressed_bytes_sum[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Profiles /s",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(pyroscope_distributor_received_compressed_bytes_count[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request Duration p99",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, route) (rate(pyroscope_request_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Go Heap",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "go_memstats_alloc_bytes{job=\"pyroscope\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Logs",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=~\"pyroscope\"} |= ``",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Traces (TraceQL)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlSearch",
          "query": "{resource.service.name=~\"pyroscope\"}",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "limit": 20,
          "tableType": "traces"
        }
      ]
    }
  ]
}
