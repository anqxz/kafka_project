{
  "title": "Admin — OTel Collector",
  "uid": "admin-otel-collector",
  "tags": [
    "admin",
    "otel"
  ],
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Up",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "up{job=\"otel-collector\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Spans Accepted /s",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (receiver) (rate(otelcol_receiver_accepted_spans[5m]))",
          "refId": "A",
          "legendFormat": "{{receiver}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Spans Refused /s",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (receiver) (rate(otelcol_receiver_refused_spans[5m]) + rate(otelcol_receiver_failed_spans[5m]))",
          "refId": "A",
          "legendFormat": "{{receiver}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Exporter Sent Spans /s",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (exporter) (rate(otelcol_exporter_sent_spans[5m]))",
          "refId": "A",
          "legendFormat": "{{receiver}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Logs Accepted /s",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (receiver) (rate(otelcol_receiver_accepted_log_records[5m]))",
          "refId": "A",
          "legendFormat": "{{receiver}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Exporter Send Failed /s",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (exporter) (rate(otelcol_exporter_send_failed_spans[5m]) + rate(otelcol_exporter_send_failed_log_records[5m]))",
          "refId": "A",
          "legendFormat": "{{exporter}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Queue Size",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "otelcol_exporter_queue_size",
          "refId": "A",
          "legendFormat": "{{exporter}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Logs",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=~\"otel.*|otelcol\"} |= ``",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Traces (TraceQL)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlSearch",
          "query": "{resource.service.name=~\"otel.*|otelcol\"}",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "limit": 20,
          "tableType": "traces"
        }
      ]
    }
  ]
}
