{
  "title": "Admin — Kafka Controllers (KRaft)",
  "uid": "admin-kafka-controllers",
  "tags": [
    "admin",
    "kafka",
    "controller",
    "kraft"
  ],
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Controllers Up",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(up{job=\"kafka-controllers\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Controller",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(kafka_controller_kafkacontroller_activecontrollercount{job=\"kafka-controllers\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Global Topics",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "max(kafka_controller_kafkacontroller_globaltopiccount{job=\"kafka-controllers\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Leader Elections /sec",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(kafka_controller_controllerstats_leaderelectionrateandtimems_count[5m]))",
          "refId": "A",
          "legendFormat": "elections"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Unclean Leader Elections /sec",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(kafka_controller_controllerstats_uncleanleaderelectionspersec_count[5m]))",
          "refId": "A",
          "legendFormat": "unclean"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Global Partitions",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "max(kafka_controller_kafkacontroller_globalpartitioncount)",
          "refId": "A",
          "legendFormat": "partitions"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "JVM Heap (controllers)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "jvm_memory_bytes_used{area=\"heap\",job=\"kafka-controllers\"}",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Logs",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=~\"broker[123]\"} |= ``",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Traces (TraceQL)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlSearch",
          "query": "{resource.service.name=~\"broker[123]\"}",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "limit": 20,
          "tableType": "traces"
        }
      ]
    }
  ]
}
